// Environment variables for Firebase configuration
// This file is used to store environment variables for the application.
// Make sure to replace the placeholder values with your actual Firebase configuration.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

// Remix admin session (use a long random string in production)
SESSION_SECRET=

// Cloudinary configuration for image uploads
// Make sure to replace the placeholder values with your actual Cloudinary configuration.
VITE_CLOUDINARY_API_KEY=
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=


// EmailJS configuration for sending emails
// Make sure to replace the placeholder values with your actual EmailJS configuration.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_AUTOREPLY_ID=
VITE_EMAILJS_PUBLIC_KEY=